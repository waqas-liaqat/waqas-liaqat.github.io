/* style.css */
:root {
    --primary-color: #00d4d4;
    --dark-bg: #1a1a1a;
    --text-color: #ffffff;
    --card-bg: #252525;
    --shadow: 0 4px 10px rgba(0, 255, 255, 0.2);
    --transition: all 0.3s ease;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Poppins', sans-serif;
}

body {
    background: #121212;
    color: var(--text-color);
    line-height: 1.6;
}

header {
    background: var(--dark-bg);
    padding: 1rem;
    position: sticky;
    top: 0;
    z-index: 1000;
}

nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
}

nav h1 {
    font-size: 1.5rem;
}

.nav-links {
    display: flex;
    list-style: none;
    gap: 1.5rem;
}

.nav-links a {
    color: var(--text-color);
    text-decoration: none;
    font-weight: 600;
    transition: var(--transition);
}

.nav-links a:hover {
    color: var(--primary-color);
}

.mobile-menu {
    display: none;
    background: none;
    border: none;
    color: var(--text-color);
    font-size: 1.5rem;
    cursor: pointer;
}

.hero {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
}

.hero-content {
    max-width: 600px;
}

.hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
}

.highlight {
    color: var(--primary-color);
}

.subtitle {
    font-size: 1.2rem;
    margin-bottom: 1.5rem;
}

.btn {
    display: inline-block;
    padding: 0.8rem 1.5rem;
    background: var(--primary-color);
    color: #121212;
    text-decoration: none;
    font-weight: bold;
    border-radius: 5px;
    transition: var(--transition);
}

.btn:hover {
    background: #ffffff;
}

.social-icons {
    margin-top: 1.5rem;
    display: flex;
    gap: 1rem;
}

.social-icons a {
    color: var(--primary-color);
    font-size: 1.5rem;
    transition: var(--transition);
}

.social-icons a:hover {
    color: var(--text-color);
}

.hero-image img {
    width: 250px;
    height: 250px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: var(--shadow);
}

.projects, .about, .contact {
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
}

.projects h2, .about h2, .contact h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    color: var(--primary-color);
    text-align: center;
}

.projects-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
}

.project-card {
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: 10px;
    box-shadow: var(--shadow);
    transition: var(--transition);
}

.project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 20px rgba(0, 255, 255, 0.4);
}

.project-card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 10px;
}

.project-info {
    padding: 1rem 0;
}

.project-info h3 {
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
    color: var(--primary-color);
}

.project-info p {
    font-size: 0.95rem;
    color: #ddd;
    margin-bottom: 1rem;
}

.about .container {
    max-width: 800px;
    margin: 0 auto;
}

.about h3 {
    font-size: 1.8rem;
    color: var(--primary-color);
    margin-top: 2rem;
    margin-bottom: 1rem;
}

.about ul {
    list-style: none;
    padding: 0;
}

.about ul li {
    font-size: 1.1rem;
    color: #ccc;
    padding: 0.5rem 0;
    display: flex;
    align-items: center;
}

.about ul li::before {
    content: "✔";
    color: var(--primary-color);
    font-weight: bold;
    margin-right: 10px;
}

.contact-container {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
}

.contact-form {
    flex: 1;
    background: var(--card-bg);
    padding: 2rem;
    border-radius: 10px;
    box-shadow: var(--shadow);
}

.contact-form input,
.contact-form textarea {
    width: 100%;
    padding: 0.8rem;
    margin-bottom: 1rem;
    background: #333;
    border: 1px solid var(--primary-color);
    border-radius: 5px;
    color: var(--text-color);
}

.contact-form textarea {
    height: 150px;
    resize: vertical;
}

.social-media {
    flex: 1;
    background: var(--card-bg);
    padding: 2rem;
    border-radius: 10px;
    box-shadow: var(--shadow);
}

.social-media ul {
    list-style: none;
    padding: 0;
}

.social-media ul li {
    margin-bottom: 1rem;
}

.social-media ul li a {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--primary-color);
    text-decoration: none;
    transition: var(--transition);
}

.social-media ul li a:hover {
    color: var(--text-color);
}

.social-media ul li a i {
    font-size: 1.2rem;
}

footer {
    background: var(--dark-bg);
    padding: 1rem;
    text-align: center;
    margin-top: 2rem;
}

footer p {
    font-size: 0.9rem;
    color: #ccc;
}

/* Responsive Design */
@media (max-width: 768px) {
    .nav-links {
        display: none;
        flex-direction: column;
        width: 100%;
        text-align: center;
        position: absolute;
        top: 70px;
        left: 0;
        background: var(--dark-bg);
        padding: 1rem 0;
    }

    .nav-links.active {
        display: flex;
    }

    .mobile-menu {
        display: block;
    }

    .hero {
        flex-direction: column;
        text-align: center;
    }

    .hero-image img {
        margin-top: 2rem;
    }

    .contact-container {
        flex-direction: column;
    }
}

@media (max-width: 480px) {
    .hero h1 {
        font-size: 2rem;
    }

    .subtitle {
        font-size: 1rem;
    }

    .btn {
        padding: 0.6rem 1.2rem;
    }
}

/* Hire Me Button Styles */
.hire-me {
    background: #1dbf73; /* Fiverr's brand color */
    color: white;
    margin-left: 10px; /* Spacing between buttons */
    display: inline-flex;
    align-items: center;
    gap: 8px; /* Space between icon and text */
    transition: background 0.3s ease;
}

.hire-me:hover {
    background: #19a463; /* Darker shade for hover effect */
}

/* Container for CTA buttons */
.cta-buttons {
    display: flex;
    gap: 10px;
    margin-top: 1.5rem;
}

/* Responsive adjustments for small screens */
@media (max-width: 480px) {
    .cta-buttons {
        flex-direction: column;
    }

    .hire-me {
        margin-left: 0;
        margin-top: 10px;
    }
}